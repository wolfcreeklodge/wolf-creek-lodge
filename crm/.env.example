# Microsoft OAuth (Azure App Registration)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://wolfcreeklodge.us/crm/auth/callback

# Session
CRM_SESSION_SECRET=change_this_to_a_random_string

# Access control (comma-separated emails)
CRM_ALLOWED_EMAILS=wolfcreeklodge@outlook.com

# Dev mode (set to true to bypass OAuth)
DEV_BYPASS_AUTH=true

# PostgreSQL (shared with website and MCP server)
DATABASE_URL=postgresql://wolfcreek:changeme_in_production@localhost:5432/wolfcreek

# Port
PORT=3000
